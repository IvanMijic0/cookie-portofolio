---
export const prerender = false;

import App from '../../components/App.tsx';
import { spreadMap } from '../../config/spreads';
import stylesheet from '../../app.css?inline';
import fs from 'node:fs';
import path from 'node:path';

const routesMap: Record<string, () => Promise<any>> = {
	"homepage": () => import("../../routes/spreads/homepage"),
	"photography": () => import("../../routes/spreads/photography"),
	"photography/kill-them-with-kindness": () => import("../../routes/spreads/kill-them-with-kindness"),
	"photography/human-rights": () => import("../../routes/spreads/human-rights"),
	"photography/double-indemnity": () => import("../../routes/spreads/double-indemnity"),
	"graphic-design": () => import("../../routes/spreads/graphic-design"),
	"graphic-design/kreativ-festival-art-direction": () => import("../../routes/spreads/kreativ-festival-art-direction"),
	"graphic-design/sjecas-li-se-doli-bel": () => import("../../routes/spreads/sjecas-li-se-doli-bel"),
	"graphic-design/chippsters-logo": () => import("../../routes/spreads/chippsters-logo"),
	"illustration": () => import("../../routes/spreads/illustration"),
	"illustration/mountain-fairy": () => import("../../routes/spreads/mountain-fairy"),
	"illustration/austen-in-watercolor": () => import("../../routes/spreads/austen-in-watercolor"),
	"illustration/mural": () => import("../../routes/spreads/mural"),
	"about-me": () => import("../../routes/spreads/about-me"),
	"contact": () => import("../../routes/spreads/contact")
};

const { lang, spread } = Astro.params;

// Default empty spread to homepage
const activeSpread = spread || 'homepage';

// Validate language
if (lang !== 'en' && lang !== 'ba') {
  return Astro.redirect(`/en/homepage`);
}

// Redirect base slug like /en to /en/homepage
if (!spread) {
  return Astro.redirect(`/${lang}/homepage`);
}

// Check if slug is valid
const moduleEntry = spreadMap[activeSpread];
const importFn = routesMap[activeSpread];

if (!moduleEntry || !importFn) {
  return Astro.redirect(`/${lang}/homepage`);
}

// Load route module to extract page meta
const routeModule = await importFn();
const PageMeta = typeof routeModule.meta === "function" 
  ? routeModule.meta({ 
      params: { lang, spread: activeSpread },
      location: { pathname: Astro.url.pathname }
    }) 
  : [];
// Parse user agent and device headers
const ua = Astro.request.headers.get('user-agent') || '';
const cfDeviceType = Astro.request.headers.get('cf-device-type') || '';
const secChUaMobile = Astro.request.headers.get('sec-ch-ua-mobile') || '';
const isMobileUA = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile/i.test(ua);
const isMobile = cfDeviceType === 'mobile' || cfDeviceType === 'tablet' || secChUaMobile === '?1' || isMobileUA;
const normalizedLang = lang === "ba" ? "bs" : (lang || "en");

// Read dynamic preloads manifest generated during build
let dynamicPreloads: string[] = [];
try {
  const preloadsPath = path.join(process.cwd(), 'dist', 'client', 'preloads.json');
  if (fs.existsSync(preloadsPath)) {
    dynamicPreloads = JSON.parse(fs.readFileSync(preloadsPath, 'utf-8'));
  }
} catch (e) {
  console.error("Failed to read preloads.json:", e);
}
---

<!DOCTYPE html>
<html lang={normalizedLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light" />
		<meta name="theme-color" content="#ffffff" />
		
		{/* 1. Critical LCP images (Highest priority) */}
		{isMobile ? (
			<>
				<link rel="preload" as="image" href="/cookie-pose-mobile.avif" type="image/avif" fetchpriority="high" />
				<link rel="preload" as="image" href="/homepage.avif" type="image/avif" fetchpriority="high" />
			</>
		) : (
			<>
				<link rel="preload" as="image" href="/homepage-left.avif" type="image/avif" fetchpriority="high" />
				<link rel="preload" as="image" href="/homepage-right.avif" type="image/avif" fetchpriority="high" />
				<link rel="preload" as="image" imagesrcset="/cookie-pose-small.avif 1x, /cookie-pose.avif 2x" fetchpriority="low" />
			</>
		)}

		{/* 2. Critical JS Modules */}
		{dynamicPreloads.map((href) => (
			<link rel="modulepreload" href={href} />
		))}
		
		{/* 3. Non-blocking Fonts (Low priority to prevent network congestion under Slow 4G) */}
		<link rel="preload" as="font" href="/fonts/bodoni-moda.woff2" type="font/woff2" crossorigin="anonymous" fetchpriority="low" />
		{!isMobile && (
			<link rel="preload" as="font" href="/fonts/bodoni-moda-italic.woff2" type="font/woff2" crossorigin="anonymous" fetchpriority="low" />
		)}
		<link rel="preload" as="font" href="/fonts/libre-bodoni.woff2" type="font/woff2" crossorigin="anonymous" fetchpriority="low" />
		{!isMobile && (
			<link rel="preload" as="font" href="/fonts/libre-bodoni-italic.woff2" type="font/woff2" crossorigin="anonymous" fetchpriority="low" />
		)}
		<link rel="preload" as="font" href="/fonts/athene-voyage.woff2" type="font/woff2" crossorigin="anonymous" fetchpriority="low" />
		<style is:inline set:html={stylesheet}></style>
		{PageMeta.map((tag: any) => {
			if (tag.title) return <title>{tag.title}</title>;
			if (tag.tagName === "link") return <link rel={tag.rel} href={tag.href} />;
			return <meta {...tag} />;
		})}
	</head>
	<body>
		<App lang={lang} isMobile={isMobile} activeSpread={activeSpread} initialPathname={Astro.url.pathname} client:load />
	</body>
</html>
